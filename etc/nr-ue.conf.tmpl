uicc0 = {
  imsi = "@IMSI@";
  key = "fec86ba6eb707ed08905757b1bb44b8f";
  opc= "C42449363BBAD02B66D16BC975D77CC1";
  dnn= "oai";
  nssai_sst=1;
}

# The rfsimulator section must use the ARRAY form -- parentheses around the
# braces. The group form (rfsimulator = { ... }) is silently ignored by this
# build: no error, but serveraddr/options are discarded and the defaults win
# (client mode, 127.0.0.1, no channel model).
#
# chanmod must be enabled UE-side as well as gNB-side: the downlink channel is
# applied at the UE.
rfsimulator = (
{
  serveraddr = "@GNB_ADDR@";
  serverport = 4043;
  options = ("chanmod");
  modelname = "AWGN";
}
);

@include "channelmod_rfsimu.conf"
